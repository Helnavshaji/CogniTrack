          {/* Blush */}
          <circle cx="36" cy="57" r="2.5" fill="var(--accent-pink)" opacity="0.4" />
          <circle cx="64" cy="57" r="2.5" fill="var(--accent-pink)" opacity="0.4" />
        </g>
      </svg>
    </div>
