<file path="frontend/src/index.css">
@import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Syne:wght@400..800&display=swap');

:root {
  --bg-dark: #0D0D1A;
  --bg-card: rgba(20, 20, 45, 0.6);
  --border-glass: rgba(255, 255, 255, 0.08);
  
  /* Vibrant Accents */
  --accent-purple: #9d4edd;
  --accent-teal: #00f5d4;
  --accent-orange: #ff9f1c;
  --accent-pink: #ff007f;
  --accent-green: #390099;
  --accent-green-bright: #39ff14;
  --accent-forest: #9d4edd;
  
  --text-primary: #F3F4F6;
  --text-secondary: #9CA3AF;
  
  --font-heading: 'Syne', system-ui, sans-serif;
  --font-body: 'DM Sans', system-ui, sans-serif;
  
  --shadow-neon-purple: 0 0 15px rgba(157, 78, 221, 0.4);
  --shadow-neon-teal: 0 0 15px rgba(0, 245, 212, 0.4);
  --shadow-neon-orange: 0 0 15px rgba(255, 159, 28, 0.4);
  --shadow-neon-pink: 0 0 15px rgba(255, 0, 127, 0.4);
}

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

body {
  background-color: var(--bg-dark);
  color: var(--text-primary);
  font-family: var(--font-body);
  min-height: 100vh;
  overflow-x: hidden;
  position: relative;
}

/* Background floating elements */
.bg-blobs {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: -2;
  overflow: hidden;
  pointer-events: none;
}

.blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.15;
  animation: float-blob 20s infinite ease-in-out alternate;
}

.blob-1 {
  width: 400px;
  height: 400px;
  background: var(--accent-purple);
  top: -10%;
  left: -10%;
  animation-duration: 25s;
}

.blob-2 {
  width: 500px;
  height: 500px;
  background: var(--accent-pink);
  bottom: -10%;
  right: -10%;
  animation-duration: 30s;
}

.blob-3 {
  width: 300px;
  height: 300px;
  background: var(--accent-teal);
  top: 40%;
  left: 50%;
  transform: translate(-50%, -50%);
  animation-duration: 18s;
}

@keyframes float-blob {
  0% {
    transform: translate(0, 0) scale(1);
  }
  100% {
    transform: translate(40px, 40px) scale(1.1);
  }
}

#root {
  width: 100%;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* Typography */
h1, h2, h3, h4, h5, h6 {
  font-family: var(--font-heading);
  font-weight: 700;
  letter-spacing: -0.5px;
}

.glass {
  background: var(--bg-card);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid var(--border-glass);
}

.btn-press {
  transition: transform 0.1s ease, box-shadow 0.2s ease;
  cursor: pointer;
}
.btn-press:active {
  transform: scale(0.95);
}

/* Character/Avatar Animations */
@keyframes blink {
  0%, 90%, 100% { transform: scaleY(1); }
  95% { transform: scaleY(0.1); }
}

@keyframes speak {
  0% { transform: scaleY(0.3); }
  100% { transform: scaleY(1.3); }
}

@keyframes pulse {
  0% { transform: scale(0.95); opacity: 0.5; }
  50% { transform: scale(1.1); opacity: 0.9; }
  100% { transform: scale(0.95); opacity: 0.5; }
}

@keyframes nod-head {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(1.5px) rotate(1deg); }
}

@keyframes tilt-head {
  0%, 100% { transform: rotate(0deg) translateY(0); }
  33% { transform: rotate(-3deg) translateY(-1px); }
  66% { transform: rotate(3deg) translateY(1px); }
}

/* Character particle/emotion overlays animations */
.char-overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 5;
}

.part-zzz, .part-heart, .part-kiss, .part-star, .part-smile {
  position: absolute;
  font-size: 14px;
  animation: float-up-fade 2s infinite ease-out;
  opacity: 0;
}

.part-zzz.p-1 { left: 30%; top: 40%; animation-delay: 0s; }
.part-zzz.p-2 { left: 25%; top: 30%; animation-delay: 0.6s; font-size: 18px; }
.part-zzz.p-3 { left: 20%; top: 20%; animation-delay: 1.2s; font-size: 22px; }

.part-heart.h-1 { left: 25%; top: 25%; animation-delay: 0s; }
.part-heart.h-2 { right: 25%; top: 25%; animation-delay: 0.7s; }
.part-heart.h-3 { left: 45%; top: 15%; animation-delay: 1.4s; }

.part-kiss.k-1 { left: 45%; top: 55%; animation-delay: 0s; }
.part-kiss.k-2 { left: 35%; top: 45%; animation-delay: 0.6s; }
.part-kiss.k-3 { right: 35%; top: 45%; animation-delay: 1.2s; }

.part-star.st-1 { left: 20%; top: 30%; animation-delay: 0s; }
.part-star.st-2 { right: 20%; top: 25%; animation-delay: 0.6s; }
.part-star.st-3 { left: 48%; top: 10%; animation-delay: 1.2s; }

.part-smile.sm-1 { left: 25%; top: 35%; animation-delay: 0s; }
.part-smile.sm-2 { right: 25%; top: 35%; animation-delay: 1s; }

@keyframes float-up-fade {
  0% { transform: translateY(15px) scale(0.6); opacity: 0; }
  20% { opacity: 1; }
  100% { transform: translateY(-30px) scale(1.1); opacity: 0; }
}

/* Wave rings for recording */
.audio-wave-ring {
  position: absolute;
  border-radius: 50%;
  border: 1.5px solid var(--accent-teal);
  width: 155px;
  height: 155px;
  z-index: 1;
  opacity: 0.4;
}
.audio-wave-ring.ring-1 {
  animation: pulse-ring 2s infinite cubic-bezier(0.215, 0.61, 0.355, 1);
}
.audio-wave-ring.ring-2 {
  animation: pulse-ring 2s infinite cubic-bezier(0.215, 0.61, 0.355, 1);
  animation-delay: 1s;
}

@keyframes pulse-ring {
  0% { transform: scale(0.9); opacity: 0.8; }
  100% { transform: scale(1.4); opacity: 0; }
}

/* Thinking bubble */
.thinking-bubble {
  position: absolute;
  top: -15px;
  background: rgba(157, 78, 221, 0.95);
  border: 1.5px solid var(--accent-purple);
  padding: 6px 14px;
  border-radius: 12px;
  font-size: 11px;
  font-weight: 700;
  color: white;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  box-shadow: var(--shadow-neon-purple);
  animation: float-bubble-bob 2s infinite ease-in-out;
  z-index: 10;
}

@keyframes float-bubble-bob {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-4px); }
}

.thinking-dot {
  animation: blink-dot 1.4s infinite both;
}
.thinking-dot.d-1 { animation-delay: 0s; }
.thinking-dot.d-2 { animation-delay: 0.2s; }
.thinking-dot.d-3 { animation-delay: 0.4s; }

@keyframes blink-dot {
  0%, 100% { opacity: 0.2; }
  50% { opacity: 1; }
}

@keyframes slideInUp {
  0% { transform: translateY(20px); opacity: 0; }
  100% { transform: translateY(0); opacity: 1; }
}

@keyframes brain-pulse {
  0% { transform: translate(-50%, -50%) scale(0.95); opacity: 0.04; }
  50% { transform: translate(-50%, -50%) scale(1.03); opacity: 0.07; }
  100% { transform: translate(-50%, -50%) scale(0.95); opacity: 0.04; }
}
